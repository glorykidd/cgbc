@page "/womenonmission"
@inject ContentService ContentService

<SeoHead Page="womenonmission" PagePath="/womenonmission" />

<section class="hero-section">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <h1>Cedar Grove Baptist Church</h1>
        <h2>Women's Ministry</h2>
        <p>"Charm is deceitful, and beauty is vain, but a woman who fears the Lord is to be
          praised."<br /><b>Proverbs
            31:30</b></p>
        <a href="/ministries?p=2" class="btn btn-success">Back to all ministries</a>
      </div>
    </div>
  </div>
</section>

<main class="container">
  <div class="container">
    <div class="row mt-3">
      <div class="col-12">
        <Card TextAlignment="Alignment.Center"
          style="background: rgba(255,255,255,0.5); border: 0px solid blue; border-radius: 20px;">
          <CardBody>
            <CardText>
              <h2>Women's Ministry @@CGBC</h2>
              <p style="font-size: 1.15em;">The vision of Cedar Grove's Women's Ministry is to encourage women to love
                the Lord our God with all their heart, soul, mind and strength; and to love our neighbors as ourselves.
                We endeavor to do so by encouraging women to worship God through a lifestyle of fellowship, prayer,
                Bible study, and service. We believe that as women grow and mature in godliness, they are better
                equipped to nurture and serve in their families, to enrich the church, and to evangelize our local
                communities and the world.</p>
              <p style="font-style: italic;"><i>"Older women likewise are to be reverent in behavior, not slanderers or
                  slaves to much wine. They are to teach what is good, and so train the young women to love their
                  husbands and children, to be self-controlled, pure, working at home, kind, and submissive to their own
                  husbands, that the word of God may not be reviled."</i> &mdash; <b>Titus 2:3-5</b></p>
            </CardText>
          </CardBody>
        </Card>
      </div>
    </div>
    <div class="row mt-3 text-center">
      <div class="col-sm-12 col-md-4 mb-3">
        <Card TextAlignment="Alignment.Center"
          style="background: rgba(255,255,255,0.6); border-radius: 20px;">
          <CardBody>
            <img style="width: 60px; margin-bottom: 10px;" src="/img/detail/bible.png" alt="Bible Studies" loading="lazy" />
            <h5>Bible Studies</h5>
            <p>Weekly bible studies for women</p>
            <a href="/calendar" class="btn btn-primary btn-sm">Calendar</a>
          </CardBody>
        </Card>
      </div>
      <div class="col-sm-12 col-md-4 mb-3">
        <Card TextAlignment="Alignment.Center"
          style="background: rgba(255,255,255,0.6); border-radius: 20px;">
          <CardBody>
            <img style="width: 60px; margin-bottom: 10px;" src="/img/detail/prayer.png" alt="Prayer Ministry" loading="lazy" />
            <h5>Prayer Ministry</h5>
            <p>Praying for our church, community, and the entire world</p>
          </CardBody>
        </Card>
      </div>
      <div class="col-sm-12 col-md-4 mb-3">
        <Card TextAlignment="Alignment.Center"
          style="background: rgba(255,255,255,0.6); border-radius: 20px;">
          <CardBody>
            <img style="width: 60px; margin-bottom: 10px;" src="/img/detail/meals.png" alt="Meals" loading="lazy" />
            <h5>Meals</h5>
            <p>Meals for a variety of situations from "just because" to Bereavement and Mercy for those in need</p>
          </CardBody>
        </Card>
      </div>
    </div>
    <div class="row mt-2">
      <div class="col-sm-12 col-md-6 mb-3">
        <Card TextAlignment="Alignment.Center"
          style="background: rgba(255,255,255,0.6); border-radius: 20px;">
          <CardBody>
            <h5>Bible Studies</h5>
            <p>Weekly bible studies on a variety of topics with rich discussions to foster growth and learning
              opportunities for women of all ages. Check the calendar to connect with us for our next session!</p>
            <a href="/calendar" class="btn btn-primary btn-sm">Calendar</a>
          </CardBody>
        </Card>
      </div>
      <div class="col-sm-12 col-md-6 mb-3">
        <Card TextAlignment="Alignment.Center"
          style="background: rgba(255,255,255,0.6); border-radius: 20px;">
          <CardBody>
            <h5>Friends Out to Lunch or Dinner (FOLD)</h5>
            <p>We love to celebrate together! We get together monthly (sometimes more) to just socialize and build
              better relationships. Check out the calendar to see when our next gathering is happening!</p>
          </CardBody>
        </Card>
      </div>
    </div>
    <div class="row">
      <div class="col-sm-12">
        <ImageCarousel FirstImage="img/detail/fold-0.jpg" Images="womensImages" />
      </div>
    </div>
  </div>
</main>

@code {
  private List<ImageSlide> womensImages = [];

  protected override void OnInitialized()
  {
    womensImages = ContentService.GetWomensImages();
  }
}
