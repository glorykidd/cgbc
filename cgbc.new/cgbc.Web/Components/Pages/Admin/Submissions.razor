@page "/admin/submissions"
@attribute [Authorize]
@layout AdminLayout
@rendermode InteractiveServer

<PageTitle>Submissions - CGBC Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Connection Card Submissions</h2>
    <a href="/admin/export/csv" class="btn btn-outline-success btn-sm">
        <i class="bi bi-download"></i> Export CSV
    </a>
</div>

<div class="row g-2 mb-3">
    <div class="col-md-6">
        <input type="text" class="form-control" placeholder="Search by name, email, or phone..."
               @bind="searchTerm" @bind:event="oninput" @bind:after="ResetAndSearch" />
    </div>
    <div class="col-md-3">
        <select class="form-select" @bind="readFilter" @bind:after="ResetAndSearch">
            <option value="">All</option>
            <option value="unread">Unread</option>
            <option value="read">Read</option>
        </select>
    </div>
    <div class="col-md-3">
        <select class="form-select" @bind="pageSize" @bind:after="ResetAndSearch">
            <option value="10">10 per page</option>
            <option value="25">25 per page</option>
            <option value="50">50 per page</option>
        </select>
    </div>
</div>

@if (items != null)
{
    <div class="card">
        <div class="card-body p-0">
            @if (items.Count == 0)
            {
                <p class="text-muted p-3 mb-0">No submissions found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th></th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Visit Status</th>
                                <th>Reason</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var card in items)
                            {
                                <tr class="@(card.IsRead ? "admin-row-read" : "admin-row-unread")">
                                    <td><span class="admin-status-dot @(card.IsRead ? "read" : "unread")"></span></td>
                                    <td><a href="/admin/submissions/@card.Id">@card.Name</a></td>
                                    <td>@card.Email</td>
                                    <td>@card.VisitStatus</td>
                                    <td>@card.ContactReason</td>
                                    <td>@card.SubmittedAt.ToLocalTime().ToString("MM/dd/yyyy")</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-secondary me-1" title="@(card.IsRead ? "Mark Unread" : "Mark Read")"
                                                @onclick="() => ToggleRead(card.Id)">
                                            <i class="bi @(card.IsRead ? "bi-envelope" : "bi-envelope-open")"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" title="Delete"
                                                @onclick="() => ConfirmDelete(card.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">Previous</button>
                </li>
                @for (var i = 1; i <= totalPages; i++)
                {
                    var pageNum = i;
                    <li class="page-item @(pageNum == currentPage ? "active" : "")">
                        <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                    </li>
                }
                <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">Next</button>
                </li>
            </ul>
        </nav>
    }
}
else
{
    <p>Loading...</p>
}

@if (showDeleteConfirm)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this submission? This cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button class="btn btn-danger" @onclick="ExecuteDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Inject] private ConnectionCardService CardService { get; set; } = default!;

    private List<ConnectionCard>? items;
    private int totalCount;
    private int currentPage = 1;
    private int pageSize = 10;
    private string searchTerm = "";
    private string readFilter = "";
    private bool showDeleteConfirm;
    private int deleteTargetId;

    private int totalPages => totalCount == 0 ? 1 : (int)Math.Ceiling((double)totalCount / pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        bool? isRead = readFilter switch
        {
            "read" => true,
            "unread" => false,
            _ => null
        };

        var result = await CardService.SearchAsync(searchTerm, isRead, currentPage, pageSize);
        items = result.Items;
        totalCount = result.TotalCount;
    }

    private async Task ResetAndSearch()
    {
        currentPage = 1;
        await LoadData();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        await LoadData();
    }

    private async Task ToggleRead(int id)
    {
        await CardService.ToggleReadAsync(id);
        await LoadData();
    }

    private void ConfirmDelete(int id)
    {
        deleteTargetId = id;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
    }

    private async Task ExecuteDelete()
    {
        await CardService.DeleteAsync(deleteTargetId);
        showDeleteConfirm = false;
        await LoadData();
    }
}
