@rendermode InteractiveServer

<div style="@ContainerStyle">
    <Carousel Autoplay="CarouselAutoPlay.StartOnPageLoad" ShowPreviousNextControls="false">
        <CarouselItem Active="true">
            <Image Src="@FirstImage" style="@ImageStyle" />
        </CarouselItem>
        @foreach (var slide in Images)
        {
            <CarouselItem>
                <Image Src="@slide.ImageUrl" style="@ImageStyle" />
            </CarouselItem>
        }
    </Carousel>
</div>

@code {
    [Parameter, EditorRequired] public string FirstImage { get; set; } = "";
    [Parameter, EditorRequired] public List<ImageSlide> Images { get; set; } = [];
    [Parameter] public int Height { get; set; } = 600;

    private string ContainerStyle => $"height: {Height}px; width: 100%; text-align: center; margin-bottom: 50px;";
    private string ImageStyle => $"height: {Height}px; border-radius: 20px;";
}
