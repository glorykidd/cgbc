@page "/menonmission"
@inject ContentService ContentService

<SeoHead Page="menonmission" PagePath="/menonmission" />

<section class="hero-section">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <h1>Cedar Grove Baptist Church</h1>
        <h2>Men on Mission</h2>
        <p>"All nations whom You made will come and worship before You, Lord, and they will glorify Your
          name."<br /><b>Psalm 86:9</b> </p>
        <a href="/ministries?p=1" class="btn btn-success">Back to all ministries</a>
      </div>
    </div>
  </div>
</section>

<main class="container">
  <div class="container">
    <div class="row mt-3">
      <div class="col-12">
        <Card TextAlignment="Alignment.Center"
          style="background: rgba(255,255,255,0.5); border: 0px solid blue; border-radius: 20px;">
          <CardBody>
            <CardText>
              <h2>Men on Mission</h2>
              <p style="font-size: 1.15em;">The Men's Ministry at Cedar Grove exists first and foremost to glorify God.
                We do this by fostering community with one another, and by God's grace, we glorify Him by living that out
                in our daily lives. We gather for breakfast on the third Saturday of each month at 8:00 am. We eat
                breakfast together, have a devotional, and pray. We tackle projects around the church grounds, take care
                of the needs at homes of older church members and persons in the community. We have a great time of
                fellowship working together.</p>
            </CardText>
          </CardBody>
        </Card>
      </div>
    </div>
    <div class="row mt-3 text-center">
      <div class="col-sm-12 col-md-4 mb-3">
        <Card TextAlignment="Alignment.Center"
          style="background: rgba(255,255,255,0.6); border-radius: 20px;">
          <CardBody>
            <img style="width: 60px; margin-bottom: 10px;" src="/img/detail/church.png" alt="Locally and more" loading="lazy" />
            <h5>Locally and more</h5>
            <p>Maintenance, groundskeeping, and community projects</p>
          </CardBody>
        </Card>
      </div>
      <div class="col-sm-12 col-md-4 mb-3">
        <Card TextAlignment="Alignment.Center"
          style="background: rgba(255,255,255,0.6); border-radius: 20px;">
          <CardBody>
            <img style="width: 60px; margin-bottom: 10px;" src="/img/detail/mission.png" alt="Our mission" loading="lazy" />
            <h5>Our mission</h5>
            <p>Glorify God in all we do and say</p>
          </CardBody>
        </Card>
      </div>
      <div class="col-sm-12 col-md-4 mb-3">
        <Card TextAlignment="Alignment.Center"
          style="background: rgba(255,255,255,0.6); border-radius: 20px;">
          <CardBody>
            <img style="width: 60px; margin-bottom: 10px;" src="/img/detail/bible.png" alt="Authority" loading="lazy" />
            <h5>Authority</h5>
            <p>The bible is the ultimate source</p>
          </CardBody>
        </Card>
      </div>
    </div>
    <div class="row mt-2">
      <div class="col-sm-12 col-md-6 mb-3">
        <Card TextAlignment="Alignment.Center"
          style="background: rgba(255,255,255,0.6); border-radius: 20px;">
          <CardBody>
            <h5>Join us</h5>
            <p>We meet on the third Saturday each month. We start with breakfast, devotions, and then make plans for
              serving our church and community. Come on down!</p>
            <a href="/calendar" class="btn btn-primary btn-sm">Calendar</a>
          </CardBody>
        </Card>
      </div>
      <div class="col-sm-12 col-md-6 mb-3">
        <Card TextAlignment="Alignment.Center"
          style="background: rgba(255,255,255,0.6); border-radius: 20px;">
          <CardBody>
            <h5>Impact</h5>
            <p>Our mission is to serve God, our local church, and the community at large.</p>
          </CardBody>
        </Card>
      </div>
    </div>
    <div class="row">
      <div class="col-sm-12">
        <ImageCarousel FirstImage="img/detail/men-0.jpg" Images="mensImages" />
      </div>
    </div>
  </div>
</main>

@code {
  private List<ImageSlide> mensImages = [];

  protected override void OnInitialized()
  {
    mensImages = ContentService.GetMensImages();
  }
}
